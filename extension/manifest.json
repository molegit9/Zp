{
  "manifest_version": 3,
  "name": "Zero-shot Phishing Detector",
  "version": "1.0",
  "description": "Hover to detect phishing instantly using Gemini 3.1 Flash Lite.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DB 캐시 초기화 관리자"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "http://localhost:8000/*"
  ]
}
